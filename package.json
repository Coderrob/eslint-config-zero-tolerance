{
  "author": {
    "name": "Robert Lindley"
  },
  "description": "Monorepo for @coderrob/eslint-plugin-zero-tolerance and @coderrob/eslint-config-zero-tolerance — strict ESLint rules and config presets for TypeScript code quality.",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/utils": "^8.56.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslint-config",
    "typescript",
    "code-quality",
    "zero-tolerance",
    "strict",
    "linting"
  ],
  "license": "Apache-2.0",
  "name": "eslint-config-zero-tolerance",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "coverage:update-badge": "node scripts/update-coverage-badge.mjs",
    "deps:circular": "madge --extensions ts --circular packages/plugin/src/index.ts",
    "deps:graph": "madge --extensions ts packages/plugin/src/index.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "pnpm build && eslint . && pnpm validate:bdd",
    "lint:fix": "pnpm build && eslint . --fix && pnpm format",
    "publish:config": "pnpm --filter @coderrob/eslint-config-zero-tolerance publish",
    "publish:plugin": "pnpm --filter @coderrob/eslint-plugin-zero-tolerance publish",
    "release:prepare": "node scripts/prepare-publish.mjs",
    "release:restore-workspace": "node scripts/restore-workspace.mjs",
    "test": "pnpm -r --if-present test && pnpm coverage:update-badge",
    "validate:bdd": "node scripts/validate-bdd-specs.mjs"
  },
  "version": "1.0.0"
}

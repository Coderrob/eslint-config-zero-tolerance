{
  "author": {
    "name": "Robert Lindley"
  },
  "bugs": {
    "url": "https://github.com/Coderrob/eslint-config-zero-tolerance/issues"
  },
  "description": "Ready-to-use ESLint configurations (recommended and strict presets) built on @coderrob/eslint-plugin-zero-tolerance — zero-tolerance code quality enforcement for TypeScript projects.",
  "devDependencies": {
    "@types/node": "^25.8.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.js"
      }
    },
    "./recommended": {
      "import": {
        "types": "./dist/recommended.d.mts",
        "default": "./dist/recommended.mjs"
      },
      "require": {
        "types": "./dist/recommended.d.cts",
        "default": "./dist/recommended.js"
      }
    },
    "./strict": {
      "import": {
        "types": "./dist/strict.d.mts",
        "default": "./dist/strict.mjs"
      },
      "require": {
        "types": "./dist/strict.d.cts",
        "default": "./dist/strict.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/Coderrob/eslint-config-zero-tolerance/",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "typescript",
    "typescript-eslint",
    "code-quality",
    "strict",
    "zero-tolerance",
    "linting",
    "recommended",
    "best-practices"
  ],
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "name": "@coderrob/eslint-config-zero-tolerance",
  "peerDependencies": {
    "@coderrob/eslint-plugin-zero-tolerance": "workspace:*",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  },
  "repository": {
    "directory": "packages/config",
    "type": "git",
    "url": "git+https://github.com/Coderrob/eslint-config-zero-tolerance.git"
  },
  "scripts": {
    "build": "tsup src/index.ts src/recommended.ts src/strict.ts --format cjs,esm --dts --clean && node ../../scripts/sync-dts-variants.mjs index recommended strict",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepack": "npm run build"
  },
  "sideEffects": false,
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "version": "1.0.0"
}

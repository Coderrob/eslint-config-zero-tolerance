{
  "author": {
    "name": "Robert Lindley"
  },
  "bugs": {
    "url": "https://github.com/Coderrob/eslint-config-zero-tolerance/issues"
  },
  "description": "Ready-to-use ESLint configurations (recommended and strict presets) built on @coderrob/eslint-plugin-zero-tolerance — zero-tolerance code quality enforcement for TypeScript projects.",
  "devDependencies": {
    "@types/node": "^20.10.6",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./recommended": {
      "types": "./dist/recommended.d.ts",
      "import": "./dist/recommended.mjs",
      "require": "./dist/recommended.js"
    },
    "./strict": {
      "types": "./dist/strict.d.ts",
      "import": "./dist/strict.mjs",
      "require": "./dist/strict.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/Coderrob/eslint-config-zero-tolerance/",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "typescript",
    "typescript-eslint",
    "code-quality",
    "strict",
    "zero-tolerance",
    "linting",
    "recommended",
    "best-practices"
  ],
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "name": "@coderrob/eslint-config-zero-tolerance",
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0 || ^9.0.0",
    "@coderrob/eslint-plugin-zero-tolerance": "workspace:*"
  },
  "repository": {
    "directory": "packages/config",
    "type": "git",
    "url": "https://github.com/Coderrob/eslint-config-zero-tolerance.git"
  },
  "scripts": {
    "build": "tsup src/index.ts src/recommended.ts src/strict.ts --format cjs,esm --dts --clean",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepack": "npm run build"
  },
  "types": "dist/index.d.ts",
  "version": "1.0.0"
}

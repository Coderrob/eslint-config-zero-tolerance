{
  "author": {
    "name": "Robert Lindley"
  },
  "bugs": {
    "url": "https://github.com/Coderrob/eslint-config-zero-tolerance/issues"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.57.2"
  },
  "description": "Strict, opinionated ESLint rules for TypeScript — enforcing type safety, code quality, testing standards, and maintainable patterns with zero exceptions.",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/parser": "^8.57.2",
    "@typescript-eslint/rule-tester": "^8.57.2",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/Coderrob/eslint-config-zero-tolerance/",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "typescript",
    "typescript-eslint",
    "code-quality",
    "type-safety",
    "strict",
    "zero-tolerance",
    "linting",
    "testing",
    "jsdoc",
    "best-practices",
    "imports",
    "naming-conventions"
  ],
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "name": "@coderrob/eslint-plugin-zero-tolerance",
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "directory": "packages/plugin",
    "type": "git",
    "url": "git+https://github.com/Coderrob/eslint-config-zero-tolerance.git"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean && node ../../scripts/sync-dts-variants.mjs index",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepack": "npm run build",
    "publish:public": "npm publish --access public",
    "test": "jest --coverage"
  },
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "version": "1.2.3"
}

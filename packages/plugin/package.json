{
  "name": "eslint-plugin-zero-tolerance",
  "version": "1.0.0",
  "description": "Strict, opinionated ESLint rules for TypeScript — enforcing type safety, code quality, testing standards, and maintainable patterns with zero exceptions.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "typescript",
    "typescript-eslint",
    "code-quality",
    "type-safety",
    "strict",
    "zero-tolerance",
    "linting",
    "testing",
    "jsdoc",
    "best-practices",
    "imports",
    "naming-conventions"
  ],
  "author": "Robert Lindley",
  "license": "Apache-2.0",
  "homepage": "https://coderrob.github.io/eslint-config-zero-tolerance/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coderrob/eslint-config-zero-tolerance.git",
    "directory": "packages/plugin"
  },
  "bugs": {
    "url": "https://github.com/Coderrob/eslint-config-zero-tolerance/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0 || ^9.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.56.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/rule-tester": "^8.56.1",
    "@typescript-eslint/utils": "^8.55.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}

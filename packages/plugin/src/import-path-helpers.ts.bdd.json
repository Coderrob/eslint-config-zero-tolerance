{
  "$schema": "../../../bdd-spec.schema.json",
  "schemaVersion": "1.0.0",
  "sourceFile": "packages/plugin/src/import-path-helpers.ts",
  "module": {
    "name": "import-path-helpers",
    "description": "Helper functions for evaluating import path characteristics used by path-based rules.",
    "exports": ["isParentDirectoryImportPath"]
  },
  "specifications": [
    {
      "feature": "isParentDirectoryImportPath",
      "scenarios": [
        {
          "name": "should return true for the exact '..' path",
          "given": "an import path of '..'",
          "when": "isParentDirectoryImportPath is called",
          "then": "returns true"
        },
        {
          "name": "should return true for paths beginning with '../'",
          "given": "an import path of '../../utils'",
          "when": "isParentDirectoryImportPath is called",
          "then": "returns true"
        },
        {
          "name": "should return false for a relative same-directory path",
          "given": "an import path of './sibling'",
          "when": "isParentDirectoryImportPath is called",
          "then": "returns false"
        },
        {
          "name": "should return false for an absolute or node_modules path",
          "given": "an import path of 'lodash'",
          "when": "isParentDirectoryImportPath is called",
          "then": "returns false"
        }
      ]
    }
  ]
}
